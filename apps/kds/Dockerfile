# Production image for the KDS SPA (Vite/React).
#
# Build from the REPO ROOT:
#   docker build -f apps/kds/Dockerfile -t spruvex-r-kds .
#
# Deliberately not parameterized by a build ARG (unlike an earlier version
# of this file) — several hosting platforms (Render among them) don't
# support passing custom Docker build arguments at all, so dashboard/pos/
# platform each get their own equally-simple, concrete Dockerfile instead
# of sharing one parameterized template.
#
# NOTE: not build-verified in this sandbox (no Docker daemon here) — validate
# with a real `docker build` in CI before a production deploy.

FROM node:22-slim AS base
RUN corepack enable
WORKDIR /repo

FROM base AS deps
COPY pnpm-lock.yaml package.json pnpm-workspace.yaml ./
COPY apps/kds/package.json apps/kds/package.json
COPY packages/ui/package.json packages/ui/package.json
COPY packages/types/package.json packages/types/package.json
COPY packages/config/package.json packages/config/package.json
RUN pnpm install --frozen-lockfile

FROM deps AS build
COPY packages/ui packages/ui
COPY packages/types packages/types
COPY packages/config packages/config
COPY apps/kds apps/kds
RUN pnpm --filter @spruvex-r/types build
RUN pnpm --filter @spruvex-r/ui build
RUN pnpm --filter @spruvex-r/kds build

FROM nginx:1.27-alpine AS runtime
COPY infra/docker/spa.nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /repo/apps/kds/dist /usr/share/nginx/html
EXPOSE 80
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
  CMD wget -qO- http://localhost/ >/dev/null || exit 1
