# Copy this file to .env and fill in real values. Never commit .env.
# One .env file is shared by api-server, the worker, and @workspace/db
# (see loadEnv.ts in each) — all three read from the workspace root.

# --- Required -----------------------------------------------------------

# PostgreSQL connection string (Neon, or any Postgres 15+). Use a SEPARATE
# database per environment (dev/staging/production) — never point staging
# or a developer's laptop at the production database.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Secret used to sign login tokens — must be a long random string (32+
# bytes) in staging/production. Generate with: openssl rand -base64 32
# Required (server refuses to start without it) when NODE_ENV=production;
# falls back to an insecure dev-only value otherwise.
JWT_SECRET=replace-with-a-long-random-string

# API server port
PORT=5000

# Frontend (pos-system) dev server port — only used by run-local.ps1
VITE_PORT=5173

# --- Environment -----------------------------------------------------------

# development | staging | production. Controls: JWT_SECRET enforcement,
# CORS default-allow-all fallback (dev only — see ALLOWED_ORIGINS below),
# and log formatting (pretty in dev, structured JSON otherwise).
NODE_ENV=development

# --- CORS --------------------------------------------------------------

# Comma-separated list of allowed origins for the API in
# staging/production, e.g. https://app.spruvex.com,https://spruvex.com
# Required in production — without it, and with NODE_ENV=production, CORS
# defaults to origin:false (blocks every browser origin) rather than
# silently allowing all. Local dev has no fixed frontend port (Vite picks
# one per run) so it falls back to allow-all only when NODE_ENV is not
# production and this is unset.
ALLOWED_ORIGINS=

# Set to "true" only when this process runs behind a reverse proxy you
# control (nginx, a cloud load balancer) that is the sole entry point —
# needed for rate limiting and audit logs to see the real client IP instead
# of the proxy's. Leave unset/false in local dev and in any deployment
# without a trusted proxy in front, since enabling it otherwise lets a
# client spoof its IP via X-Forwarded-For.
TRUST_PROXY=false

# --- Optional: caching, rate limiting, background jobs ---------------------

# Redis connection string. Optional for api-server (caching/rate-limiting
# fall back to in-process, single-instance-only behavior when unset — fine
# for one dev machine, NOT fine for a multi-instance production deploy).
# REQUIRED for the worker process (background job queue has no fallback).
REDIS_URL=

LOG_LEVEL=info

# --- Optional: AI features (platform-level fallback key) -------------------

# Only used when a tenant hasn't configured their own BYOK key in
# Settings > AI. Leave unset in dev — the "mock" provider (no key, no
# network) is used for all AI feature testing/CI.
AI_PROVIDER=mock
ANTHROPIC_API_KEY=

# --- Not yet used in production: external integrations ---------------------

# Ecommerce channel connectors (Salla/Zid/Shopify) and payment gateways
# (Tabby/Tamara/Moyasar) are built but intentionally NOT wired to any real
# credentials yet — every tenant integration is configured per-company
# through the app itself (Settings > Integrations / Payments), not via
# platform-wide env vars, and defaults to the "mock" provider until a real
# merchant/gateway account exists. Nothing to set here before launch.
