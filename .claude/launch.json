{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api-server",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["-C", "spruvex-app", "--filter", "@workspace/api-server", "run", "dev"],
      "port": 5000
    },
    {
      "name": "pos-system",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["-C", "spruvex-app", "--filter", "@workspace/pos-system", "run", "dev"],
      "port": 5173,
      "env": {
        "PORT": "5173",
        "BASE_PATH": "/",
        "API_PROXY_TARGET": "http://localhost:5000",
        "NODE_ENV": "development"
      }
    }
  ]
}
