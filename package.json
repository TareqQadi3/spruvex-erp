{
  "name": "spruvex-r",
  "private": true,
  "version": "0.1.0",
  "description": "SpruVex R — Restaurant Operating System (SaaS) for Saudi Arabia & GCC",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:migrate:dev": "pnpm --filter @spruvex-r/api db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @spruvex-r/api db:migrate:deploy",
    "db:seed": "pnpm --filter @spruvex-r/api db:seed"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
