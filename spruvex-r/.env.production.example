# Production environment for docker-compose.prod.yml.
# Copy to `.env.production`, fill in real values, and NEVER commit the copy.
#
#   cp .env.production.example .env.production
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d

# --- Postgres ---
# Superuser password used only to run infra/postgres/init on first boot.
POSTGRES_SUPERUSER_PASSWORD="generate-a-long-random-value"
# Runtime (RLS-enforced) and migration/seed (BYPASSRLS) role passwords.
# infra/postgres/init/01-roles.sql creates these roles with hardcoded dev
# passwords ("spruvex_app"/"spruvex_admin") — for production, edit that file
# (or set the passwords via `ALTER ROLE ... PASSWORD` once) to match these
# values before first boot.
SPRUVEX_APP_PASSWORD="generate-a-long-random-value"
SPRUVEX_ADMIN_PASSWORD="generate-a-long-random-value"

# --- Auth ---
JWT_SECRET="generate-a-long-random-value-32-bytes-or-more"
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# --- Public URLs ---
# Base URL of the customer ordering app (encoded into table QR codes).
ORDERING_BASE_URL="https://order.yourdomain.com"
# The API's own public HTTPS origin, reachable directly from customers'
# browsers — NOT the internal docker-network address. Baked into the
# ordering app's client bundle at build time for its realtime order-tracking
# socket connection; get this wrong and order tracking silently never goes
# "live" in production even though everything else works.
PUBLIC_API_ORIGIN="https://api.yourdomain.com"
# Comma-separated origins allowed by CORS — every frontend origin actually
# served in production (dashboard/pos/kds/ordering/platform). No wildcards.
CORS_ORIGINS="https://app.yourdomain.com,https://pos.yourdomain.com,https://kds.yourdomain.com,https://order.yourdomain.com,https://admin.yourdomain.com"

# --- Platform admin bootstrap (one-time; safe to unset after first use) ---
PLATFORM_ADMIN_EMAIL=""
PLATFORM_ADMIN_PASSWORD=""

# --- Monitoring (pilot launch; optional) ---
# Error tracking: leave blank to disable (zero behavior change, zero external
# calls). Set to a Sentry DSN to have unhandled/5xx exceptions reported there.
SENTRY_DSN=""
