# --- Database ---
# Runtime connection — spruvex_app has NOBYPASSRLS, so Row-Level Security is always enforced.
DATABASE_URL="postgresql://spruvex_app:spruvex_app@localhost:5432/spruvex_r?schema=public"
# Migration/seed connection — spruvex_admin owns the schema and has BYPASSRLS.
ADMIN_DATABASE_URL="postgresql://spruvex_admin:spruvex_admin@localhost:5432/spruvex_r?schema=public"

# --- Redis (used from Phase 4 onward: Socket.io adapter, BullMQ) ---
REDIS_URL="redis://localhost:6379"

# --- Auth ---
# HMAC secret for JWT access tokens — generate a long random value per environment.
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_ACCESS_TTL_SECONDS=900        # 15 minutes
REFRESH_TOKEN_TTL_DAYS=30

# --- QR ordering ---
# Base URL of the customer ordering app — encoded into table QR codes:
# {ORDERING_BASE_URL}/menu/{restaurant-slug}/table/{token}
ORDERING_BASE_URL="http://localhost:3002"

# --- Platform admin bootstrap (optional) ---
# If both are set, `pnpm db:seed` creates this platform admin account when
# none exists yet — the only way to get the first /platform login, since
# there is no self-registration for platform admins.
PLATFORM_ADMIN_EMAIL=""
PLATFORM_ADMIN_PASSWORD=""

# --- API ---
PORT=3000
NODE_ENV=development
# Comma-separated origins allowed by CORS (dashboard, pos, kds, ordering, platform)
CORS_ORIGINS="http://localhost:5173,http://localhost:3002,http://localhost:5175,http://localhost:5176,http://localhost:3001"

# --- apps/ordering (Next.js customer app) ---
# Server-side: where SSR pages fetch the public API from.
API_ORIGIN="http://localhost:3000"
# Also server-side, read at request time and passed to the client as a prop
# (not a NEXT_PUBLIC_* build-time var — see app/order/[orderId]/page.tsx):
# the API's public origin, safe to expose since it's just the API host.
# Socket.io connects here directly from the browser for realtime order
# tracking.
PUBLIC_API_ORIGIN="http://localhost:3000"
