# Copy this file to .env and fill in real values. Never commit .env.

# Dev server port (only used when running `vite dev`/`preview` directly)
PORT=5174

# Base path the site is served from — "/" for a normal domain root deploy
BASE_PATH=/

# Backend API base URL — the marketing site's pricing page and other public
# reads come from here (GET /api/public/plans, etc). Point at your
# api-server instance for this environment (local/staging/production —
# never mix, e.g. never point a production site build at a staging API).
VITE_API_URL=http://localhost:5000

# pos-system URL — every "Get started" / plan CTA deep-links to
# {VITE_APP_URL}/signup for the real signup wizard.
VITE_APP_URL=http://localhost:5173

# Password gate for the lightweight built-in admin panel (?admin route) —
# set a real value in staging/production. Never left blank in a public
# deploy.
VITE_ADMIN_PANEL_PASSWORD=
